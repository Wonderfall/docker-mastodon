#!/bin/sh
set -eu

prepare_s6_scandir() {
  runtime_parent=

  for candidate in /run /tmp; do
    if [ -d "$candidate" ] && [ -w "$candidate" ]; then
      runtime_parent="$candidate/s6"
      break
    fi
  done

  if [ -z "$runtime_parent" ]; then
    echo "No writable runtime directory found for s6. Mount /tmp or /run as writable when using read_only." >&2
    exit 1
  fi

  mkdir -p "$runtime_parent"
  scan_dir="$(mktemp -d "$runtime_parent/scan.XXXXXX")"
  stage_service_tree /etc/s6.d "$scan_dir"
  printf '%s\n' "$scan_dir"
}

stage_service_tree() {
  src_dir="$1"
  dst_dir="$2"

  mkdir -p "$dst_dir"

  for entry in "$src_dir"/* "$src_dir"/.[!.]* "$src_dir"/..?*; do
    [ -e "$entry" ] || continue
    name="${entry##*/}"
    dst_entry="$dst_dir/$name"

    if [ -d "$entry" ]; then
      stage_service_tree "$entry" "$dst_entry"
    else
      ln -s "$entry" "$dst_entry"
    fi
  done
}

echo "
---------------------------------------------
     _____         _         _
    |     |___ ___| |_ ___ _| |___ ___
    | | | | .'|_ -|  _| . | . | . |   |
    |_|_|_|__,|___|_| |___|___|___|_|_|

A GNU Social-compatible microblogging server
   https://github.com/mastodon/mastodon
---------------------------------------------
UID/GID settings
---------------------------------------------
User  ID : $(id -u)
Group ID : $(id -g)
---------------------------------------------
Logs location
---------------------------------------------
Sidekiq   : /mastodon/log/sidekiq.log
Streaming : /mastodon/log/streaming.log
Web       : /mastodon/log/web.log
---------------------------------------------
"

if [ "${RUN_DB_MIGRATIONS:-true}" = "true" ]; then
  echo "Running database migrations task..."
  bundle exec rake db:migrate
fi

echo "Executing process(es)..."
if [ "$#" -eq 0 ]; then
  runtime_scandir="$(prepare_s6_scandir)"
  echo "Using s6 scan directory: ${runtime_scandir}"
  exec s6-svscan "$runtime_scandir"
fi

if [ "$#" -eq 2 ] && [ "$1" = "s6-svscan" ] && [ "$2" = "/etc/s6.d" ]; then
  runtime_scandir="$(prepare_s6_scandir)"
  echo "Using s6 scan directory: ${runtime_scandir}"
  exec s6-svscan "$runtime_scandir"
fi

exec "$@"
